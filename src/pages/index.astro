---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostCard from '../components/PostCard.astro';
import profile from '../data/profile.json';
import publications from '../data/publications.json';

const projects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="site-shell hero">
    <div class="hero-copy">
      <h1>Michele Pascale</h1>
      <p class="lede">{profile.summary}</p>
      <div class="hero-details" aria-label="Profile details">
        <p>
          Supervised by{' '}
          {
            profile.intro.supervisors.map((supervisor, index) => (
              <>
                <a href={supervisor.href}>{supervisor.name}</a>
                {index === profile.intro.supervisors.length - 2 ? ' and ' : ''}
              </>
            ))
          }.
        </p>
        <p>{profile.intro.previous}</p>
        <div>
          <span class="detail-label">Research interests</span>
          <div class="tag-list">
            {profile.intro.focus.map((item) => <span class="tag">{item}</span>)}
          </div>
        </div>
      </div>
    </div>
    <aside class="portrait-card" aria-label="Profile summary">
      <div class="portrait-frame">
        <img src="/images/profile.jpg" alt="Portrait of Michele Pascale" />
      </div>
      <div>
        <strong>{profile.name}</strong>
        <p>{profile.title} and {profile.affiliation}</p>
      </div>
    </aside>
  </section>

  <section class="site-shell section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Selected Research</p>
        <h2>Current academic focus</h2>
        <p>Inverse problems, mathematical imaging, and learning-based reconstruction methods.</p>
      </div>
      <a class="button" href="/research/">All research</a>
    </div>
    <div class="two-col">
      {
        publications.map((paper) => (
          <article class="card">
            <span class="date">{paper.year}</span>
            <h3>{paper.title}</h3>
            <p>{paper.venue}</p>
            <p>{paper.summary}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="site-shell section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Projects</p>
        <h2>Technical work</h2>
        <p>Selected research engineering, machine learning, and imaging projects.</p>
      </div>
      <a class="button" href="/projects/">All projects</a>
    </div>
    <div class="grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="site-shell section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Blog</p>
        <h2>Writing and notes</h2>
        <p>Markdown posts with local media and math support.</p>
      </div>
      <a class="button" href="/blog/">Read blog</a>
    </div>
    <div class="grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
