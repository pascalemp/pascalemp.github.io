---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="Page not found.">
  <section class="site-shell page-title">
    <p class="eyebrow">404</p>
    <h1>That page is not here.</h1>
    <p>The site may have moved during the redesign.</p>
    <div class="actions">
      <a class="button primary" href="/">Go home</a>
      <a class="button" href="/blog/">Visit blog</a>
    </div>
  </section>
</BaseLayout>
