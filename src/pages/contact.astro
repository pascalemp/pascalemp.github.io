---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';
---

<BaseLayout title="Contact" description="Contact links for Michele Pascale.">
  <section class="site-shell page-title">
    <h1>Contact</h1>
    <p>Email and public profiles.</p>
  </section>
  <section class="site-shell section">
    <div class="grid">
      {
        profile.links.map((link) => (
          <a class="card card-link" href={link.href}>
            <h3>{link.label}</h3>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
